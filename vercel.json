{
  "outputDirectory": "static",
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://rx-ai-production.up.railway.app/api/$1"
    },
    {
      "source": "/ws/(.*)",
      "destination": "https://rx-ai-production.up.railway.app/ws/$1"
    },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/pharmacist", "destination": "/pharmacist.html" },
    { "source": "/track", "destination": "/track.html" },
    { "source": "/waitlist", "destination": "/waitlist.html" },
    { "source": "/verification", "destination": "/verification.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/js/config.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
