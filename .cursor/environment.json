{
  "name": "rx-ai-cloud-env",
  "install": "python3 -m pip install -U pip && python3 -m pip install -r requirements.txt",
  "start": "python3 -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
  "ports": [
    {
      "name": "api",
      "port": 8000
    }
  ],
  "terminals": [
    {
      "name": "api-server",
      "description": "Run FastAPI development server",
      "command": "python3 -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload"
    }
  ]
}
